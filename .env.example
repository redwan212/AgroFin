# ─────────────────────────────────────────────────────────────────────
# AgroFin — Environment Configuration
# ─────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and edit the values for your environment.
# DO NOT commit .env to source control (already in .gitignore).
# ─────────────────────────────────────────────────────────────────────

# ─── Application ───────────────────────────────────────────────
APP_NAME=AgroFin
APP_ENV=development        # development | staging | production
APP_DEBUG=true             # true on dev; ALWAYS false in production
APP_URL=http://localhost
APP_TIMEZONE=Asia/Dhaka
APP_KEY=                   # 32+ random chars — generate with: openssl rand -hex 32

# ─── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=agrofin
DB_USER=root
DB_PASS=                   # XAMPP default is empty
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ─── Session & Security ───────────────────────────────────────
SESSION_LIFETIME=7200      # seconds (2 hours)
SESSION_SECURE=false       # true in production (HTTPS only)
SESSION_SAMESITE=Lax       # Lax | Strict | None
CSRF_TOKEN_LIFETIME=3600

# ─── File Uploads ─────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,webp

# ─── Cron / Scheduled Tasks ───────────────────────────────────
CRON_ENABLED=true
CRON_TOKEN=                # required for cron HTTP triggers; generate random

# ─── SMS Gateway (Step 9, not wired yet) ──────────────────────
# Leave empty during dev — OTP will be logged to error log instead of sent
SMS_PROVIDER=              # ssl_wireless | mim | banglalink | log
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=AgroFin

# ─── Payment Gateway (Step 10, not wired yet) ─────────────────
PAYMENT_PROVIDER=          # sslcommerz | bkash | mock | disabled
PAYMENT_SANDBOX=true       # use gateway sandbox during dev
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SUCCESS_URL=
SSLCOMMERZ_FAIL_URL=
SSLCOMMERZ_CANCEL_URL=
SSLCOMMERZ_IPN_URL=

# ─── External APIs (future) ───────────────────────────────────
WEATHER_PROVIDER=openweathermap   # openweathermap | none
WEATHER_API_KEY=00031d10219221085b2b35a290a513b0
PRICE_FEED_URL=
PRICE_FEED_FORMAT=auto            # auto | csv | json

# ─── LLM Assistant (Update Chunk 5) ───────────────────────────
LLM_PROVIDER=none          # none | anthropic | openai | gemini
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5 # claude-haiku-4-5 | gpt-4o-mini | gemini-2.5-flash
LLM_MAX_TOKENS=800
LLM_DAILY_QUOTA_PER_USER=50

# ─── Logging ──────────────────────────────────────────────────
LOG_CHANNEL=file           # file | syslog | stderr
LOG_LEVEL=info             # debug | info | warning | error
LOG_PATH=storage/logs
LOG_RETENTION_DAYS=30      # log_rotate cron task

# ─── Session hardening (Update Chunk 7) ───────────────────────
SESSION_IDLE_TIMEOUT_MIN=60    # force re-login after idle minutes
SESSION_ABS_TIMEOUT_HOURS=24   # force re-login after this many hours regardless
SESSION_FINGERPRINT=true       # bind session to IP class + UA hash
APP_KEY=                        # random 32+ char string for fingerprint salt

# ─── Search (Update Chunk 6) ──────────────────────────────────
SEARCH_DRIVER=sql                       # sql | meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700  # Docker default
MEILISEARCH_API_KEY=                    # optional master key
MEILISEARCH_CROPS_INDEX=crops

# ─── Cache (Step 11, not wired yet) ───────────────────────────
CACHE_DRIVER=file          # file | redis | memcached | none
CACHE_TTL_DEFAULT=3600
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
